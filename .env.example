# ──────────────────────────────────────────────────────────────
# Agent-G .env template
#
# Copy this to `.env` and fill in the values for the backends you
# actually use. Every field is optional — Agent-G picks up whatever
# is present and complains only about the ones it genuinely needs
# for the provider you selected.
#
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────


# ──────────────────────────────────────────────────────────────
# 1. Ghidra installation (REQUIRED for bare-metal deploys)
# ──────────────────────────────────────────────────────────────
# Path to the Ghidra distribution directory. Download from
# https://github.com/NationalSecurityAgency/ghidra/releases and
# point this at the unzipped folder (the one containing `support/`).
# Not required when running inside the sandbox/docker-compose image —
# Ghidra is baked into the container at /opt/ghidra there.
GHIDRA_INSTALL_DIR=/opt/ghidra_12.0.2_PUBLIC


# ──────────────────────────────────────────────────────────────
# 2. LLM provider selection
# ──────────────────────────────────────────────────────────────
# One of: ollama | external | custom_api
# - ollama     — local Ollama daemon at OLLAMA_BASE_URL
# - external   — generic cloud provider routed by EXTERNAL_PROVIDER
# - custom_api — OpenAI-compatible endpoint (including Codex ChatGPT backend)
LLM_PROVIDER=ollama


# ── Ollama (local or cloud) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=300


# ── External provider (Google / Anthropic / OpenAI) ──
# EXTERNAL_PROVIDER picks which generate_* method the client uses.
# EXTERNAL_API_KEY and EXTERNAL_MODEL are read by all three paths.
#
# Google example:
#   EXTERNAL_PROVIDER=google
#   EXTERNAL_MODEL=gemini-3.1-flash-lite-preview
#   EXTERNAL_API_KEY=AIza...
#
# Anthropic example:
#   EXTERNAL_PROVIDER=anthropic
#   EXTERNAL_MODEL=claude-opus-4-6
#   EXTERNAL_API_KEY=sk-ant-api03-...
#
# OpenAI example (direct API key, NOT Codex OAuth):
#   EXTERNAL_PROVIDER=openai
#   EXTERNAL_MODEL=gpt-5.4
#   EXTERNAL_API_KEY=sk-...
EXTERNAL_PROVIDER=
EXTERNAL_MODEL=
EXTERNAL_API_KEY=
EXTERNAL_BASE_URL=
EXTERNAL_TIMEOUT=300

# Google-specific (used by EXTERNAL_PROVIDER=google):
GOOGLE_API_KEY=
GOOGLE_MODEL=


# ── Custom API / Codex OAuth / OpenAI-compatible ──
# Use this branch for: Codex desktop OAuth (ChatGPT backend), Together AI,
# Fireworks, Groq, or any other OpenAI-compatible endpoint.
CUSTOM_API_URL=
CUSTOM_API_KEY=
CUSTOM_API_MODEL=
# auth_mode: auto (default) | api_key | codex_oauth
CUSTOM_API_AUTH_MODE=auto
# Path to Codex desktop's auth.json (only used when auth_mode=codex_oauth).
# Default: ~/.codex/auth.json
CUSTOM_API_CODEX_AUTH_FILE=


# ──────────────────────────────────────────────────────────────
# 3. Ghidra MCP server (managed automatically in headless mode)
# ──────────────────────────────────────────────────────────────
GHIDRA_BASE_URL=http://localhost:8080
GHIDRA_TIMEOUT=30


# ──────────────────────────────────────────────────────────────
# 4. Secrets backend
# ──────────────────────────────────────────────────────────────
# By default secrets come from env vars above. For production you can
# chain backends — first hit wins:
#   AGENT_G_SECRETS_BACKEND=winvault:env
#   AGENT_G_SECRETS_BACKEND=vault:env
#   AGENT_G_SECRETS_BACKEND=awssm:env
#
# Backends needed for each path:
#   winvault → pip install "agent-g[winvault]"  (keyring)
#   vault    → pip install "agent-g[vault]"     (hvac)
#   awssm    → pip install "agent-g[awssm]"     (boto3)
AGENT_G_SECRETS_BACKEND=env

# Vault-specific (only needed if using AGENT_G_SECRETS_BACKEND=vault)
VAULT_ADDR=
VAULT_TOKEN=
AGENT_G_VAULT_PATH=secret/data/agent-g

# AWS Secrets Manager (only needed if using AGENT_G_SECRETS_BACKEND=awssm)
AWS_REGION=
AGENT_G_AWS_SECRET_NAME=agent-g

# Dev-only JSON file backend (never use in production)
# AGENT_G_SECRETS_FILE=.secrets.json


# ──────────────────────────────────────────────────────────────
# 5. Ghidra HTTP server authentication
# ──────────────────────────────────────────────────────────────
# The OGhidraHeadlessServer.java post-script enforces bearer auth on
# every endpoint except /health. Agent-G auto-generates a token per
# instance (32-byte URL-safe random) and writes it to a sidecar file
# that the Python tool runner reads. Set this ONLY if you want to
# pin a known token for debugging.
#
# Set AGENT_G_GHIDRA_AUTH_DISABLE=1 to disable auth entirely — dev
# only, never in a shared environment.
AGENT_G_GHIDRA_AUTH_TOKEN=
# AGENT_G_GHIDRA_AUTH_DISABLE=0


# ──────────────────────────────────────────────────────────────
# 6. Circuit breaker tuning (optional)
# ──────────────────────────────────────────────────────────────
# These override the in-code defaults in src/runtime/circuit_breaker.py.
# Typical production values are conservative — tune up for chatty APIs,
# down for critical ones.
# AGENT_G_CB_FAILURE_THRESHOLD=0.5
# AGENT_G_CB_COOLDOWN_INITIAL_S=30
# AGENT_G_CB_COOLDOWN_MAX_S=600


# ──────────────────────────────────────────────────────────────
# 7. Observability (optional)
# ──────────────────────────────────────────────────────────────
# Where structured JSON logs are written. Stderr is always used; this
# adds a file sink alongside.
# AGENT_G_LOG_FILE=logs/agent-g.jsonl

# Where per-investigation run artifacts go (trace.jsonl, checkpoint.json,
# events.jsonl, provenance.json). Default: runs/<trace_id>/
# AGENT_G_RUNS_DIR=runs

# Where the SQLite result store lives.
# AGENT_G_RESULT_STORE=runs/results.sqlite
