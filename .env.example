# Agent-G configuration
# Copy to .env and uncomment ONE provider section below.
#
#   cp .env.example .env


# ── Ghidra ───────────────────────────────────────────────────
# Bare-metal: path to the unzipped Ghidra folder
# Docker: leave commented, it's baked into the container
#GHIDRA_INSTALL_DIR=/opt/ghidra_12.0.2_PUBLIC

# Docker users: uncomment these two lines instead
#AGENT_G_MODE=docker
#GHIDRA_BASE_URL=http://localhost:18080


# ── LLM provider (pick ONE) ─────────────────────────────────

# --- Anthropic (Claude) ---
#LLM_PROVIDER=external
#EXTERNAL_PROVIDER=anthropic
#EXTERNAL_API_KEY=sk-ant-api03-...
#EXTERNAL_MODEL=claude-opus-4-6

# --- Google (Gemini) ---
#LLM_PROVIDER=external
#EXTERNAL_PROVIDER=google
#EXTERNAL_API_KEY=AIza...
#EXTERNAL_MODEL=gemini-3.1-flash-lite-preview

# --- OpenAI (GPT) ---
#LLM_PROVIDER=external
#EXTERNAL_PROVIDER=openai
#EXTERNAL_API_KEY=sk-...
#EXTERNAL_MODEL=gpt-5.4

# --- Ollama (local) ---
#LLM_PROVIDER=ollama
#OLLAMA_MODEL=gemma4:e4b
#OLLAMA_BASE_URL=http://localhost:11434
