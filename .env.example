# Agent-G configuration
# Copy to .env, fill in the required fields, then run: agent-g doctor
#
#   cp .env.example .env


# ── Required: Ghidra location ───────────────────────────────
# Pick ONE of these two options:

# Option A — Bare-metal: path to your unzipped Ghidra folder
GHIDRA_INSTALL_DIR=

# Option B — Docker: uncomment both lines below (and leave GHIDRA_INSTALL_DIR blank)
#AGENT_G_MODE=docker
#GHIDRA_BASE_URL=http://localhost:18080


# ── Required: LLM provider ──────────────────────────────────
# Set LLM_PROVIDER and fill in the matching section below.
LLM_PROVIDER=external

# Which cloud provider to use (required when LLM_PROVIDER=external)
EXTERNAL_PROVIDER=google
EXTERNAL_API_KEY=
EXTERNAL_MODEL=gemini-3.1-flash-lite-preview

# ── Alternative providers ────────────────────────────────────
# To use a different provider, change LLM_PROVIDER and
# EXTERNAL_PROVIDER above, then set the key and model.
#
# Google:    EXTERNAL_PROVIDER=google    EXTERNAL_MODEL=gemini-3.1-flash-lite-preview
# OpenAI:   EXTERNAL_PROVIDER=openai    EXTERNAL_MODEL=gpt-5.4
# Ollama:   LLM_PROVIDER=ollama         OLLAMA_MODEL=gemma4:e4b
#                                        OLLAMA_BASE_URL=http://localhost:11434
