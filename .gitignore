# ── Secrets + local config ─────────────────────────
.env
.env.*
!.env.example
.secrets.json
*.key
*.pem
.credentials/
auth.json

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
build/
dist/
wheels/
*.egg-info/
*.egg
